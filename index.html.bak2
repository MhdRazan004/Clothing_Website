<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Pegas Clothing - Premium Online Clothing Store. Shop latest trends in Men, Women, and Kids wear.">
    <title>Pegas Clothing | Premium Fashion Store</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <div class="page-loader" id="pageLoader"><div class="loader-spinner"></div></div>

    <!-- TOP BAR -->
    <div class="top-bar">
        <div class="container">
            <div class="contact-info">
                <a href="tel:+94771234567"><i class="fas fa-phone-alt"></i><span>+94 77 123 4567</span></a>
                <a href="mailto:info@pegasclothing.com"><i class="fas fa-envelope"></i><span>info@pegasclothing.com</span></a>
                <span class="free-shipping"><i class="fas fa-truck"></i> Free Shipping Over LKR 5,000</span>
            </div>
            <div class="user-actions">
                <a href="#" id="registerLink"><i class="fas fa-user-plus"></i> Register</a>
                <a href="#" id="signinLink"><i class="fas fa-sign-in-alt"></i> Sign in</a>
            </div>
        </div>
    </div>

    <!-- MAIN HEADER -->
    <header class="main-header">
        <div class="container">
            <a href="#" class="logo" id="logoLink">
                <div class="logo-text">PEGAS<span>CLOTHING</span></div>
            </a>
            <div class="search-bar">
                <input type="text" placeholder="Search for clothing, shoes, accessories..." id="searchInput">
                <select class="category-select" id="categorySelect">
                    <option>All Categories</option>
                    <option>New Arrivals</option>
                    <option>Men's Wear</option>
                    <option>Women's Wear</option>
                    <option>Kids &amp; Baby</option>
                    <option>Accessories</option>
                    <option>Footwear</option>
                    <option>Sale</option>
                </select>
                <button class="search-btn" id="searchBtn"><i class="fas fa-search"></i></button>
            </div>
            <div class="header-actions">
                <a href="#" class="header-action" id="wishlistLink"><i class="far fa-heart"></i><span>Wishlist</span></a>
                <a href="#" class="cart-action" id="cartLink">
                    <div class="cart-icon-wrapper"><i class="fas fa-shopping-bag"></i><span class="cart-badge">0</span></div>
                    <div class="cart-info"><span class="cart-label">Cart</span><span class="cart-amount">LKR 0.00</span></div>
                </a>
            </div>
        </div>
    </header>

    <!-- NAVIGATION -->
    <nav class="nav-bar" id="navBar">
        <div class="container">
            <div class="all-categories-btn" id="allCategoriesBtn">
                <i class="fas fa-bars"></i><span>SHOP BY CATEGORY</span>
                <ul class="categories-dropdown" id="categoriesDropdown">
                    <li><a href="#"><i class="fas fa-venus"></i> Women's Fashion</a></li>
                    <li><a href="#"><i class="fas fa-mars"></i> Men's Fashion</a></li>
                    <li><a href="#"><i class="fas fa-child"></i> Kids &amp; Baby</a></li>
                    <li><a href="#"><i class="fas fa-tshirt"></i> T-Shirts &amp; Tops</a></li>
                    <li><a href="#"><i class="fas fa-shoe-prints"></i> Footwear</a></li>
                    <li><a href="#"><i class="fas fa-gem"></i> Accessories</a></li>
                    <li><a href="#"><i class="fas fa-percent"></i> Clearance Sale</a></li>
                </ul>
            </div>
            <ul class="nav-links">
                <li><a href="#newArrivalsSection">New Arrivals</a></li>
                <li><a href="#" class="deals-link" id="dealsLink">Hot Deals</a></li>
                <li><a href="#menSection">Men</a></li>
                <li><a href="#womenSection">Women</a></li>
                <li><a href="#kidsSection">Kids</a></li>
                <li><a href="#accessoriesSection">Accessories</a></li>
            </ul>
        </div>
    </nav>

    <!-- HERO SLIDER -->
    <section class="hero-section" id="heroSection">
        <div class="hero-slider" id="heroSlider">
            <div class="hero-slide active">
                <img src="images/hero_banner.png" alt="Hero Banner" class="slide-bg-img">
                <div class="slide-content">
                    <h2>New Season Collection 2026</h2>
                    <h1>Elevate Your Style</h1>
                    <p class="slide-desc">Discover the latest trends in fashion. Premium quality clothing for every occasion.</p>
                    <button class="shop-now-btn">SHOP NOW <i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
            <div class="hero-slide">
                <img src="images/hero_banner.png" alt="Summer Sale Banner" class="slide-bg-img">
                <div class="slide-content">
                    <h2>Up to 50% Off</h2>
                    <h1>Summer Sale is Here</h1>
                    <p class="slide-desc">Grab your favorite outfits at unbeatable prices. Limited time offer!</p>
                    <button class="shop-now-btn">SHOP SALE <i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
            <div class="hero-slide">
                <img src="images/hero_banner.png" alt="Women's Collection Banner" class="slide-bg-img">
                <div class="slide-content">
                    <h2>Exclusive Collection</h2>
                    <h1>Women's Premium Wear</h1>
                    <p class="slide-desc">Elegant dresses, stylish tops, and more for the modern woman.</p>
                    <button class="shop-now-btn">EXPLORE <i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
            <div class="hero-slide">
                <img src="images/hero_banner.png" alt="Men's Collection Banner" class="slide-bg-img">
                <div class="slide-content">
                    <h2>Men's Collection</h2>
                    <h1>Redefine Your Wardrobe</h1>
                    <p class="slide-desc">Classic and contemporary menswear. From casual to formal.</p>
                    <button class="shop-now-btn">SHOP MEN <i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
        </div>
        <button class="slider-arrow prev" id="sliderPrev"><i class="fas fa-chevron-left"></i></button>
        <button class="slider-arrow next" id="sliderNext"><i class="fas fa-chevron-right"></i></button>
        <div class="slider-dots" id="sliderDots">
            <span class="slider-dot active" data-slide="0"></span>
            <span class="slider-dot" data-slide="1"></span>
            <span class="slider-dot" data-slide="2"></span>
            <span class="slider-dot" data-slide="3"></span>
        </div>
    </section>

    <!-- NEW ARRIVALS -->
    <section class="container animate-on-scroll" id="newArrivalsSection">
        <div class="section-header"><h2><i class="fas fa-star" style="margin-right:10px"></i> New Arrivals</h2><a href="#" class="view-all-btn">View All <i class="fas fa-arrow-right" style="margin-left:4px;font-size:10px"></i></a></div>
        <div class="section-tabs">
            <span class="section-tab active">All</span>
            <span class="section-tab">Women</span>
            <span class="section-tab">Men</span>
            <span class="section-tab">Kids</span>
            <span class="section-tab">Accessories</span>
        </div>
        <div class="products-section">
            <div class="products-grid" id="newArrivalsGrid">
                <div class="product-card"><div class="product-badge new">NEW</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #ffecd2, #fcb69f);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Product Image</span></div></div><div class="product-info"><div class="product-category">Women's Tops</div><div class="product-name">Floral Print Ruffle Sleeve Blouse</div><div class="product-price">LKR 2,490</div><div class="product-colors"><span class="color-dot" style="background:#e74c3c;"></span><span class="color-dot" style="background:#3498db;"></span><span class="color-dot" style="background:#2ecc71;"></span></div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-badge new">NEW</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #a1c4fd, #c2e9fb);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Product Image</span></div></div><div class="product-info"><div class="product-category">Men's Casual</div><div class="product-name">Classic Fit Cotton Polo T-Shirt</div><div class="product-price">LKR 1,890</div><div class="product-colors"><span class="color-dot" style="background:#2c3e50;"></span><span class="color-dot" style="background:#ecf0f1;border:1px solid #ddd;"></span><span class="color-dot" style="background:#e74c3c;"></span></div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #f093fb, #f5576c);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Product Image</span></div></div><div class="product-info"><div class="product-category">Women's Dresses</div><div class="product-name">Elegant A-Line Midi Dress</div><div class="product-price">LKR 4,290</div><div class="product-colors"><span class="color-dot" style="background:#8e44ad;"></span><span class="color-dot" style="background:#2c3e50;"></span></div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-badge new">NEW</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #c2e9fb, #a1c4fd);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Product Image</span></div></div><div class="product-info"><div class="product-category">Men's Shirts</div><div class="product-name">Slim Fit Checked Formal Shirt</div><div class="product-price">LKR 3,190</div><div class="product-colors"><span class="color-dot" style="background:#2980b9;"></span><span class="color-dot" style="background:#ecf0f1;border:1px solid #ddd;"></span></div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
            </div>
        </div>
    </section>

    <!-- PROMO BANNERS -->
    <div class="container promo-banner-section animate-on-scroll">
        <div class="promo-banner-duo">
            <div class="promo-banner-card" style="background: linear-gradient(135deg, #e94560, #0f3460);"><div class="promo-banner-content"><span class="promo-tag">Limited Time</span><h3>Up to 50% OFF</h3><p>On all Women's dresses and tops</p><a href="#" class="promo-link">Shop Now <i class="fas fa-arrow-right"></i></a></div></div>
            <div class="promo-banner-card" style="background: linear-gradient(135deg, #0f3460, #533483);"><div class="promo-banner-content"><span class="promo-tag">New Season</span><h3>Men's Collection</h3><p>Fresh styles for the modern man</p><a href="#" class="promo-link">Explore <i class="fas fa-arrow-right"></i></a></div></div>
        </div>
    </div>

    <!-- MEN'S COLLECTION -->
    <section class="container animate-on-scroll" id="menSection">
        <div class="section-header men-header"><h2><i class="fas fa-mars" style="margin-right:10px"></i> Men's Collection</h2><a href="#" class="view-all-btn">View All <i class="fas fa-arrow-right" style="margin-left:4px;font-size:10px"></i></a></div>
        <div class="category-pills"><span class="category-pill active">All</span><span class="category-pill">T-Shirts</span><span class="category-pill">Shirts</span><span class="category-pill">Trousers</span><span class="category-pill">Jeans</span><span class="category-pill">Jackets</span></div>
        <div class="products-section">
            <div class="products-grid" id="menGrid">
                <div class="product-card"><div class="product-badge discount">20%</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #e8ecf3, #d5dce8);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">T-Shirt Image</span></div></div><div class="product-info"><div class="product-category">Men's T-Shirts</div><div class="product-name">Graphic Print Round Neck T-Shirt</div><div class="product-price-wrapper"><div class="product-price">LKR 1,590</div><div class="product-price-old">LKR 1,990</div></div><div class="product-sizes">S  M  L  XL  XXL</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #e8ecf3, #d5dce8);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Shirt Image</span></div></div><div class="product-info"><div class="product-category">Men's Shirts</div><div class="product-name">Linen Blend Casual Shirt - Navy</div><div class="product-price">LKR 3,490</div><div class="product-sizes">S  M  L  XL</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-badge discount">15%</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #e8ecf3, #d5dce8);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Jeans Image</span></div></div><div class="product-info"><div class="product-category">Men's Jeans</div><div class="product-name">Slim Fit Stretch Denim Jeans - Dark Blue</div><div class="product-price-wrapper"><div class="product-price">LKR 3,890</div><div class="product-price-old">LKR 4,590</div></div><div class="product-sizes">28  30  32  34  36</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-badge new">NEW</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #e8ecf3, #d5dce8);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Jacket Image</span></div></div><div class="product-info"><div class="product-category">Men's Jackets</div><div class="product-name">Bomber Jacket with Zip Closure - Black</div><div class="product-price">LKR 5,990</div><div class="product-sizes">M  L  XL  XXL</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
            </div>
        </div>
    </section>

    <!-- WOMEN'S COLLECTION -->
    <section class="container animate-on-scroll" id="womenSection">
        <div class="section-header women-header"><h2><i class="fas fa-venus" style="margin-right:10px"></i> Women's Collection</h2><a href="#" class="view-all-btn">View All <i class="fas fa-arrow-right" style="margin-left:4px;font-size:10px"></i></a></div>
        <div class="category-pills"><span class="category-pill active">All</span><span class="category-pill">Dresses</span><span class="category-pill">Tops &amp; Blouses</span><span class="category-pill">Skirts</span><span class="category-pill">Trousers</span><span class="category-pill">Sarees</span></div>
        <div class="products-section">
            <div class="products-grid" id="womenGrid">
                <div class="product-card"><div class="product-badge discount">30%</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #ffecd2, #fcb69f);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Dress Image</span></div></div><div class="product-info"><div class="product-category">Women's Dresses</div><div class="product-name">Floral Wrap Midi Dress - Summer Collection</div><div class="product-price-wrapper"><div class="product-price">LKR 3,490</div><div class="product-price-old">LKR 4,990</div></div><div class="product-sizes">XS  S  M  L  XL</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #f093fb, #f5576c);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Top Image</span></div></div><div class="product-info"><div class="product-category">Women's Tops</div><div class="product-name">Puff Sleeve Crop Top - Blush Pink</div><div class="product-price">LKR 1,990</div><div class="product-sizes">XS  S  M  L</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-badge new">NEW</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #a18cd1, #fbc2eb);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Skirt Image</span></div></div><div class="product-info"><div class="product-category">Women's Skirts</div><div class="product-name">Pleated Midi Skirt - Lavender</div><div class="product-price">LKR 2,890</div><div class="product-sizes">S  M  L  XL</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-badge discount">25%</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #84fab0, #8fd3f4);"><span class="placeholder-icon"><i class="fas fa-tshirt"></i></span><span class="placeholder-label">Saree Image</span></div></div><div class="product-info"><div class="product-category">Women's Sarees</div><div class="product-name">Silk Blend Saree with Embroidered Border</div><div class="product-price-wrapper"><div class="product-price">LKR 6,740</div><div class="product-price-old">LKR 8,990</div></div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
            </div>
        </div>
    </section>

    <!-- STYLE BANNER -->
    <div class="container promo-banner-section animate-on-scroll">
        <div class="style-banner" style="background: linear-gradient(135deg, #1a1a2e, #e94560);"><div class="style-banner-content"><h2>Get Inspired</h2><h3>Style Guide &amp; Lookbook 2026</h3><p>Discover curated outfits and the latest fashion trends</p><a href="#" class="style-banner-btn">View Lookbook <i class="fas fa-arrow-right"></i></a></div></div>
    </div>

    <!-- KIDS COLLECTION -->
    <section class="container animate-on-scroll" id="kidsSection">
        <div class="section-header kids-header"><h2><i class="fas fa-child" style="margin-right:10px"></i> Kids Collection</h2><a href="#" class="view-all-btn">View All <i class="fas fa-arrow-right" style="margin-left:4px;font-size:10px"></i></a></div>
        <div class="category-pills"><span class="category-pill active">All</span><span class="category-pill">Boys</span><span class="category-pill">Girls</span><span class="category-pill">Baby</span><span class="category-pill">School Wear</span></div>
        <div class="products-section">
            <div class="products-grid" id="kidsGrid">
                <div class="product-card"><div class="product-badge new">NEW</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #f6d365, #fda085);"><span class="placeholder-icon"><i class="fas fa-child"></i></span><span class="placeholder-label">Kids Image</span></div></div><div class="product-info"><div class="product-category">Boys</div><div class="product-name">Dinosaur Print Cotton T-Shirt Set</div><div class="product-price">LKR 1,490</div><div class="product-sizes">2-3Y  4-5Y  6-7Y  8-9Y</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-badge discount">20%</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #fbc2eb, #a18cd1);"><span class="placeholder-icon"><i class="fas fa-child"></i></span><span class="placeholder-label">Kids Image</span></div></div><div class="product-info"><div class="product-category">Girls</div><div class="product-name">Butterfly Print Frock with Bow Detail</div><div class="product-price-wrapper"><div class="product-price">LKR 1,590</div><div class="product-price-old">LKR 1,990</div></div><div class="product-sizes">2-3Y  4-5Y  6-7Y</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #84fab0, #8fd3f4);"><span class="placeholder-icon"><i class="fas fa-baby"></i></span><span class="placeholder-label">Baby Image</span></div></div><div class="product-info"><div class="product-category">Baby</div><div class="product-name">Soft Cotton Baby Romper Set - 3 Pack</div><div class="product-price">LKR 2,290</div><div class="product-sizes">0-3M  3-6M  6-12M</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
                <div class="product-card"><div class="product-badge new">NEW</div><div class="product-wishlist"><i class="far fa-heart"></i></div><div class="product-image"><div class="img-placeholder" style="background: linear-gradient(135deg, #a1c4fd, #c2e9fb);"><span class="placeholder-icon"><i class="fas fa-child"></i></span><span class="placeholder-label">Kids Image</span></div></div><div class="product-info"><div class="product-category">School Wear</div><div class="product-name">School Uniform Polo Shirt - White</div><div class="product-price">LKR 990</div><div class="product-sizes">4-5Y  6-7Y  8-9Y  10-11Y</div><button class="add-to-cart-btn"><i class="fas fa-shopping-bag"></i> Add to Cart</button></div></div>
            </div>
        </div>
    </section>

    <!-- ACCESSORIES -->
    <section class="container animate-on-scroll" id="accessoriesSection">
        <div class="section-header accessories-header"><h2><i class="fas fa-gem" style="margin-right:10px"></i> Accessories &amp; Footwear</h2><a href="#" class="view-all-btn">View All <i class="fas fa-arrow-right" style="margin-left:4px;font-size:10px"></i></a></div>
        <div class="category-pills"><span class="category-pill active">All</span><span class="category-pill">Bags</span><span class="category-pill">Watches</span><span class="category-pill">Sunglasses</span><span class="category-pill">Shoes</span><span class="category-pill">Belts</span></div>
        <div class="products-section">
            <div class="products-grid" id="accessoriesGrid">
