/* ============================================
   MySoftlogic.lk Clone - Complete CSS
   ============================================ */

/* Google Fonts */
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;700;900&display=swap');

/* CSS Reset & Variables */
:root {
    --primary-color: #1a1a1a;
    --primary-light: #333333;
    --accent-color: #c5a059;
    /* Gold accent */
    --accent-red: #ff3f6c;
    /* Vibrant pink/red for sales */
    --bg-light: #f9f9f9;
    --bg-white: #ffffff;
    --bg-grey: #eeeeee;
    --text-dark: #1a1a1a;
    --text-grey: #666666;
    --text-light: #999999;
    --footer-bg: #111111;
    --footer-dark: #000000;
    --border-color: #dddddd;
    --shadow-light: 0 2px 10px rgba(0, 0, 0, 0.05);
    --shadow-medium: 0 4px 20px rgba(0, 0, 0, 0.08);
    --shadow-hover: 0 10px 40px rgba(0, 0, 0, 0.12);
    --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    --radius: 0px;
    /* Sharp corners for high fashion */
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Poppins', sans-serif;
    background: var(--bg-light);
    color: var(--text-dark);
    line-height: 1.6;
    overflow-x: hidden;
}

a {
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
}

ul,
li {
    list-style: none;
}

img {
    max-width: 100%;
    height: auto;
    display: block;
}

/* ============================================
   IMAGE PLACEHOLDER CONTAINERS
   ============================================ */
.img-placeholder {
    background: linear-gradient(135deg, #e8ecf3 0%, #d5dce8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    border-radius: 4px;
}

.img-placeholder::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    animation: shimmer 2s infinite;
}

.img-placeholder .placeholder-icon {
    color: #b0bec5;
    font-size: 40px;
    z-index: 1;
}

.img-placeholder .placeholder-label {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    color: #90a4ae;
    background: rgba(255, 255, 255, 0.8);
    padding: 2px 10px;
    border-radius: 10px;
    white-space: nowrap;
    z-index: 1;
}

@keyframes shimmer {
    0% {
        left: -100%;
    }

    100% {
        left: 100%;
    }
}

/* ============================================
   TOP BAR
   ============================================ */
.top-bar {
    background: var(--bg-grey);
    padding: 8px 0;
    font-size: 13px;
    color: var(--text-grey);
    border-bottom: 1px solid var(--border-color);
}

.top-bar .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.top-bar .contact-info {
    display: flex;
    align-items: center;
    gap: 25px;
}

.top-bar .contact-info a {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--text-grey);
}

.top-bar .contact-info a:hover {
    color: var(--primary-blue);
}

.top-bar .contact-info i {
    font-size: 15px;
}

.top-bar .user-actions {
    display: flex;
    align-items: center;
    gap: 20px;
}

.top-bar .user-actions a {
    display: flex;
    align-items: center;
    gap: 5px;
    color: var(--text-grey);
    font-weight: 500;
}

.top-bar .user-actions a:hover {
    color: var(--primary-blue);
}

/* ============================================
   MAIN HEADER
   ============================================ */
.main-header {
    background: var(--bg-white);
    padding: 15px 0;
    box-shadow: var(--shadow-light);
    position: relative;
    z-index: 100;
}

.main-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
}

/* Logo */
.logo {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 200px;
}

.logo .cart-icon-logo {
    font-size: 28px;
    color: var(--primary-blue);
}

.logo-text {
    font-size: 22px;
    font-weight: 300;
    color: var(--text-grey);
    letter-spacing: -0.5px;
}

.logo-text span {
    font-weight: 700;
    color: var(--primary-blue);
}

.logo-text .domain {
    font-size: 16px;
    color: var(--text-grey);
    font-weight: 400;
}

/* Search Bar */
.search-bar {
    flex: 1;
    display: flex;
    align-items: center;
    max-width: 650px;
    border: 2px solid var(--border-color);
    border-radius: 6px;
    overflow: hidden;
    transition: var(--transition);
}

.search-bar:focus-within {
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 3px rgba(46, 49, 146, 0.1);
}

.search-bar input {
    flex: 1;
    padding: 12px 18px;
    border: none;
    outline: none;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: var(--text-dark);
}

.search-bar input::placeholder {
    color: var(--text-light);
}

.search-bar .category-select {
    padding: 12px 15px;
    border: none;
    border-left: 1px solid var(--border-color);
    outline: none;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    color: var(--text-grey);
    background: var(--bg-grey);
    cursor: pointer;
    min-width: 140px;
}

.search-bar .search-btn {
    padding: 12px 20px;
    background: var(--primary-blue);
    color: white;
    border: none;
    cursor: pointer;
    font-size: 18px;
    transition: var(--transition);
}

.search-bar .search-btn:hover {
    background: var(--primary-dark);
}

/* Header Actions */
.header-actions {
    display: flex;
    align-items: center;
    gap: 25px;
}

.header-action {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    position: relative;
}

.header-action i {
    font-size: 24px;
    color: var(--text-dark);
}

.header-action span {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-dark);
}

.header-action:hover i,
.header-action:hover span {
    color: var(--primary-blue);
}

.cart-action {
    display: flex;
    align-items: center;
    gap: 8px;
}

.cart-icon-wrapper {
    position: relative;
}

.cart-badge {
    position: absolute;
    top: -8px;
    right: -10px;
    background: var(--primary-blue);
    color: white;
    font-size: 10px;
    font-weight: 700;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.cart-info {
    display: flex;
    flex-direction: column;
    font-size: 12px;
}

.cart-info .cart-label {
    font-weight: 600;
    color: var(--text-dark);
}

.cart-info .cart-amount {
    color: var(--text-grey);
    font-size: 11px;
}

/* ============================================
   STICKY NAVIGATION
   ============================================ */
.nav-bar {
    background: var(--bg-white);
    border-bottom: 3px solid var(--primary-blue);
    position: sticky;
    top: 0;
    z-index: 999;
    box-shadow: var(--shadow-medium);
}

.nav-bar .container {
    display: flex;
    align-items: center;
}

.all-categories-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 30px;
    background: var(--primary-blue);
    color: white;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    cursor: pointer;
    letter-spacing: 0.5px;
    position: relative;
    min-width: 240px;
}

.all-categories-btn i {
    font-size: 20px;
}

.all-categories-btn:hover {
    background: var(--primary-dark);
}

/* Categories Dropdown */
.categories-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    width: 280px;
    background: white;
    box-shadow: var(--shadow-medium);
    border-radius: 0 0 8px 8px;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: var(--transition);
    z-index: 1000;
}

.all-categories-btn:hover .categories-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}

.categories-dropdown li a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 20px;
    font-size: 13px;
    color: var(--text-dark);
    border-bottom: 1px solid #f0f0f0;
    transition: var(--transition);
}

.categories-dropdown li a:hover {
    background: var(--bg-light);
    color: var(--primary-blue);
    padding-left: 28px;
}

.categories-dropdown li a i {
    font-size: 16px;
    width: 20px;
    text-align: center;
    color: var(--primary-blue);
}

/* Nav Links */
.nav-links {
    display: flex;
    align-items: center;
    flex: 1;
}

.nav-links li a {
    display: block;
    padding: 14px 22px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-dark);
    transition: var(--transition);
    position: relative;
}

.nav-links li a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 3px;
    background: var(--primary-blue);
    transition: var(--transition);
}

.nav-links li a:hover::after {
    width: 80%;
}

.nav-links li a:hover {
    color: var(--primary-blue);
}

.nav-links .deals-link {
    background: var(--accent-red);
    color: white !important;
    font-weight: 600;
}

.nav-links .deals-link:hover {
    background: #c41019;
}

.nav-links .deals-link::after {
    display: none;
}

.nav-links .voucher-link {
    color: var(--accent-purple) !important;
    font-weight: 600;
}

.nav-links .other-payments-link {
    background: var(--accent-yellow);
    color: var(--text-dark) !important;
    font-weight: 500;
}

.nav-links .other-payments-link:hover {
    background: #e6c42f;
}

.nav-links .other-payments-link::after {
    display: none;
}

/* ============================================
   CONTAINER
   ============================================ */
.container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 20px;
}

/* ============================================
   HERO SLIDER
   ============================================ */
.hero-section {
    position: relative;
    overflow: hidden;
    margin-bottom: 0;
}

.hero-slider {
    position: relative;
    width: 100%;
    height: 480px;
    overflow: hidden;
}

.hero-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.8s ease;
    display: flex;
    align-items: center;
}

.hero-slide.active {
    opacity: 1;
}

.hero-slide .slide-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
}

.hero-slide .slide-bg-placeholder {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
}

.slide-content {
    position: relative;
    z-index: 2;
    padding: 40px 60px;
    max-width: 600px;
}

.slide-content h2 {
    font-size: 18px;
    font-weight: 400;
    color: white;
    margin-bottom: 5px;
}

.slide-content h1 {
    font-size: 36px;
    font-weight: 800;
    color: white;
    line-height: 1.2;
    margin-bottom: 15px;
}

.slide-content .slide-specs {
    display: flex;
    gap: 15px;
    margin-bottom: 15px;
}

.slide-content .spec-badge {
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    padding: 6px 14px;
    border-radius: 4px;
    color: white;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.3);
}

.slide-content .slide-price {
    font-size: 28px;
    font-weight: 800;
    color: var(--accent-yellow);
    margin-bottom: 15px;
}

.slide-content .buy-now-btn {
    background: var(--accent-red);
    color: white;
    padding: 12px 35px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 15px;
    display: inline-block;
    transition: var(--transition);
    border: none;
    cursor: pointer;
}

.slide-content .buy-now-btn:hover {
    background: #c41019;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(227, 30, 36, 0.4);
}

/* Payment icons row */
.payment-icons-row {
    position: absolute;
    bottom: 30px;
    left: 60px;
    z-index: 3;
    display: flex;
    gap: 10px;
    align-items: center;
}

.payment-icon-badge {
    background: white;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    color: var(--text-dark);
    box-shadow: var(--shadow-light);
}

/* Slider dots */
.slider-dots {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 5;
}

.slider-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: var(--transition);
    border: 2px solid rgba(255, 255, 255, 0.6);
}

.slider-dot.active {
    background: var(--primary-blue);
    border-color: white;
    transform: scale(1.2);
}

.slider-dot:hover {
    background: rgba(255, 255, 255, 0.8);
}

/* Slider arrows */
.slider-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 45px;
    height: 45px;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: var(--primary-blue);
    cursor: pointer;
    z-index: 5;
    transition: var(--transition);
    box-shadow: var(--shadow-medium);
}

.slider-arrow:hover {
    background: var(--primary-blue);
    color: white;
}

.slider-arrow.prev {
    left: 20px;
}

.slider-arrow.next {
    right: 20px;
}

/* ============================================
   PROMOTIONS BAR
   ============================================ */
.promotions-bar {
    background: white;
    padding: 20px 0;
    border-bottom: 1px solid var(--border-color);
}

.promo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
}

.promo-card {
    height: 160px;
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
    transition: var(--transition);
    position: relative;
}

.promo-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
}

.promo-card .img-placeholder {
    width: 100%;
    height: 100%;
    border-radius: var(--radius);
}

/* ============================================
   SECTION HEADERS
   ============================================ */
.section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 25px;
    background: var(--primary-blue);
    border-radius: var(--radius) var(--radius) 0 0;
    margin-top: 30px;
}

.section-header h2 {
    color: white;
    font-size: 20px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.section-header .view-all-btn {
    color: white;
    font-size: 13px;
    font-weight: 500;
    padding: 6px 18px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 20px;
    transition: var(--transition);
}

.section-header .view-all-btn:hover {
    background: white;
    color: var(--primary-blue);
}

/* Tab navigation */
.section-tabs {
    display: flex;
    background: var(--primary-blue);
    padding: 0 25px;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
}

.section-tabs::-webkit-scrollbar {
    display: none;
}

.section-tab {
    padding: 12px 22px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: var(--transition);
    border-bottom: 3px solid transparent;
    position: relative;
}

.section-tab:hover {
    color: white;
    background: rgba(255, 255, 255, 0.1);
}

.section-tab.active {
    color: white;
    border-bottom-color: var(--accent-yellow);
    font-weight: 600;
}

/* ============================================
   PRODUCT GRID & CARDS
   ============================================ */
.products-section {
    background: white;
    border-radius: 0 0 var(--radius) var(--radius);
    box-shadow: var(--shadow-light);
    margin-bottom: 30px;
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    padding: 0;
}

.product-card {
    border: 1px solid #f0f0f0;
    padding: 20px;
    text-align: center;
    transition: var(--transition);
    position: relative;
    background: white;
    cursor: pointer;
}

.product-card:hover {
    box-shadow: var(--shadow-hover);
    z-index: 2;
    transform: scale(1.02);
}

.product-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 3;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: white;
}

.product-badge.discount {
    background: var(--accent-red);
}

.product-badge.new {
    background: var(--primary-blue);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.product-image {
    width: 100%;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
    position: relative;
}

.product-image img {
    max-height: 180px;
    max-width: 100%;
    object-fit: contain;
    transition: var(--transition);
}

.product-card:hover .product-image img {
    transform: scale(1.05);
}

.product-image .img-placeholder {
    width: 160px;
    height: 180px;
    border-radius: 8px;
}

.product-price {
    font-size: 18px;
    font-weight: 700;
    color: var(--accent-red);
    margin-bottom: 5px;
}

.product-price-old {
    font-size: 13px;
    color: var(--text-light);
    text-decoration: line-through;
    margin-bottom: 5px;
}

.product-name {
    font-size: 13px;
    color: var(--text-dark);
    line-height: 1.5;
    font-weight: 400;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.product-card .out-of-stock {
    position: absolute;
    top: 12px;
    right: 0;
    background: #78909c;
    color: white;
    font-size: 10px;
    font-weight: 600;
    padding: 4px 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    writing-mode: vertical-lr;
    border-radius: 4px 0 0 4px;
}

.product-card .ar-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    display: flex;
    gap: 4px;
}

.product-card .ar-badge span {
    background: rgba(46, 49, 146, 0.1);
    color: var(--primary-blue);
    font-size: 9px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 3px;
    border: 1px solid rgba(46, 49, 146, 0.2);
}

/* ============================================
   BRAND STORE SECTION
   ============================================ */
.brand-store {
    margin-bottom: 30px;
}

.brand-header {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    padding: 20px 30px;
    border-radius: var(--radius) var(--radius) 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.brand-header h2 {
    color: white;
    font-size: 22px;
    font-weight: 700;
}

.brand-tabs {
    display: flex;
    gap: 0;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 25px;
    overflow: hidden;
}

.brand-tab {
    padding: 8px 20px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition);
    white-space: nowrap;
}

.brand-tab:hover {
    color: white;
}

.brand-tab.active {
    background: white;
    color: var(--primary-blue);
    border-radius: 25px;
    font-weight: 600;
}

.brand-products {
    background: white;
    border-radius: 0 0 var(--radius) var(--radius);
    box-shadow: var(--shadow-light);
}

/* ============================================
   CATEGORY PILLS
   ============================================ */
.category-pills {
    display: flex;
    gap: 10px;
    padding: 15px 25px;
    background: white;
    border-bottom: 1px solid #f0f0f0;
    overflow-x: auto;
    scrollbar-width: none;
}

.category-pills::-webkit-scrollbar {
    display: none;
}

.category-pill {
    padding: 8px 20px;
    border: 1px solid var(--border-color);
    border-radius: 25px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-grey);
    cursor: pointer;
    white-space: nowrap;
    transition: var(--transition);
}

.category-pill:hover,
.category-pill.active {
    background: var(--primary-blue);
    color: white;
    border-color: var(--primary-blue);
}

/* ============================================
   PROMOTIONAL BANNER SECTIONS
   ============================================ */
.promo-banner-section {
    margin: 30px 0;
}

.promo-banner-section .promo-banner {
    width: 100%;
    height: 200px;
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
    transition: var(--transition);
}

.promo-banner-section .promo-banner:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
}

.promo-banner-section .promo-banner .img-placeholder {
    width: 100%;
    height: 100%;
    border-radius: var(--radius);
}

.promo-double {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 30px 0;
}

.promo-double .promo-item {
    height: 180px;
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
    transition: var(--transition);
}

.promo-double .promo-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
}

.promo-double .promo-item .img-placeholder {
    width: 100%;
    height: 100%;
    border-radius: var(--radius);
}

/* ============================================
   FOOTER
   ============================================ */
.footer {
    background: var(--footer-bg);
    color: rgba(255, 255, 255, 0.7);
    padding: 50px 0 0;
    margin-top: 40px;
}

.footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.footer-col h3 {
    color: white;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 20px;
    position: relative;
    padding-bottom: 10px;
}

.footer-col h3::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background: var(--primary-blue);
    border-radius: 2px;
}

.footer-col p {
    font-size: 13px;
    margin-bottom: 8px;
    line-height: 1.8;
}

.footer-col .phone-number {
    font-size: 22px;
    font-weight: 700;
    color: white;
    margin-bottom: 15px;
}

.footer-col ul li {
    margin-bottom: 10px;
}

.footer-col ul li a {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 8px;
}

.footer-col ul li a:hover {
    color: white;
    padding-left: 5px;
}

.footer-col ul li a::before {
    content: '›';
    font-size: 16px;
    font-weight: 700;
}

/* Social Icons */
.social-icons {
    display: flex;
    gap: 12px;
    margin-top: 20px;
}

.social-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: var(--transition);
    font-size: 16px;
}

.social-icon:hover {
    background: var(--primary-blue);
    border-color: var(--primary-blue);
    transform: translateY(-3px);
}

/* Group Companies */
.group-companies {
    text-align: center;
    padding: 30px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.group-companies h3 {
    color: var(--primary-blue);
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 25px;
}

.group-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 50px;
}

.group-logo-item {
    color: white;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 3px;
    opacity: 0.8;
    transition: var(--transition);
}

.group-logo-item:hover {
    opacity: 1;
}

.group-logo-item .sub-brand {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0;
    display: block;
}

/* Copyright */
.copyright-bar {
    background: var(--footer-dark);
    padding: 18px 0;
}

.copyright-bar .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.copyright-bar p {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
}

.payment-methods {
    display: flex;
    gap: 12px;
    align-items: center;
}

.payment-method {
    background: white;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    color: var(--text-dark);
}

.payment-method.visa {
    color: #1a1f71;
}

.payment-method.mastercard {
    color: #eb001b;
}

.payment-method.amex {
    color: #006fcf;
}

/* ============================================
   SCROLL-TO-TOP BUTTON
   ============================================ */
.scroll-top-btn {
    position: fixed;
    bottom: 30px;
    right: 30px;
    width: 50px;
    height: 50px;
    background: var(--primary-blue);
    color: white;
    border: none;
    border-radius: 50%;
    font-size: 20px;
    cursor: pointer;
    box-shadow: var(--shadow-medium);
    transition: var(--transition);
    opacity: 0;
    visibility: hidden;
    z-index: 999;
}

.scroll-top-btn.visible {
    opacity: 1;
    visibility: visible;
}

.scroll-top-btn:hover {
    background: var(--primary-dark);
    transform: translateY(-3px);
}

/* ============================================
   ANIMATIONS
   ============================================ */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }

    to {
        opacity: 1;
    }
}

.animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
}

.animate-on-scroll.animated {
    opacity: 1;
    transform: translateY(0);
}

/* ============================================
   RESPONSIVE DESIGN
   ============================================ */
@media (max-width: 1200px) {
    .products-grid {
        grid-template-columns: repeat(3, 1fr);
    }

    .footer-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 992px) {
    .main-header .container {
        flex-wrap: wrap;
    }

    .search-bar {
        order: 3;
        max-width: 100%;
        flex-basis: 100%;
    }

    .nav-links {
        overflow-x: auto;
        scrollbar-width: none;
    }

    .nav-links::-webkit-scrollbar {
        display: none;
    }

    .hero-slider {
        height: 350px;
    }

    .promo-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .top-bar .contact-info {
        gap: 12px;
    }

    .top-bar .contact-info span {
        display: none;
    }

    .logo {
        min-width: 150px;
    }

    .logo-text {
        font-size: 18px;
    }

    .all-categories-btn {
        min-width: auto;
        padding: 14px 20px;
    }

    .all-categories-btn span {
        display: none;
    }

    .products-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .hero-slider {
        height: 280px;
    }

    .slide-content h1 {
        font-size: 24px;
    }

    .slide-content .slide-price {
        font-size: 22px;
    }

    .footer-grid {
        grid-template-columns: 1fr;
    }

    .promo-grid {
        grid-template-columns: 1fr 1fr;
    }

    .promo-double {
        grid-template-columns: 1fr;
    }

    .header-actions {
        gap: 15px;
    }

    .header-action span {
        display: none;
    }
}

@media (max-width: 480px) {
    .products-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .product-card {
        padding: 12px;
    }

    .product-image {
        height: 140px;
    }

    .product-price {
        font-size: 15px;
    }

    .product-name {
        font-size: 11px;
    }

    .hero-slider {
        height: 220px;
    }

    .slide-content {
        padding: 20px 30px;
    }

    .slide-content h1 {
        font-size: 18px;
    }

    .slider-arrow {
        width: 35px;
        height: 35px;
        font-size: 16px;
    }

    .promo-grid {
        grid-template-columns: 1fr;
    }
}

/* ============================================
   LOADING ANIMATION
   ============================================ */
.page-loader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity 0.5s ease;
}

.page-loader.hidden {
    opacity: 0;
    pointer-events: none;
}

.loader-spinner {
    width: 50px;
    height: 50px;
    border: 4px solid var(--bg-grey);
    border-top-color: var(--primary-blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}

/* ============================================
   WHATSAPP BUTTON
   ============================================ */
.whatsapp-btn {
    position: fixed;
    bottom: 90px;
    right: 30px;
    width: 55px;
    height: 55px;
    background: #25d366;
    color: white;
    border: none;
    border-radius: 50%;
    font-size: 28px;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
    transition: var(--transition);
    z-index: 998;
    display: flex;
    align-items: center;
    justify-content: center;
}

.whatsapp-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
}